---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import LinkButton from "./LinkButton.astro";

export interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
---

{
  page.lastPage > 1 && (
    <nav
      class="mx-auto mb-8 flex max-w-app items-center justify-center gap-4 px-6 font-sans text-sm font-bold"
      aria-label="Pagination"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={[
          "press-btn inline-flex items-center gap-1 rounded-[var(--radius)] bg-muted px-4 py-2 no-underline select-none",
          { "pointer-events-none opacity-50 shadow-none": !page.url.prev },
        ]}
        ariaLabel="Previous"
      >
        <IconArrowLeft class="inline-block rtl:rotate-180" />
        Prev
      </LinkButton>
      <span class="rounded-full border-2 border-border bg-muted px-4 py-2">
        {page.currentPage} / {page.lastPage}
      </span>
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={[
          "press-btn inline-flex items-center gap-1 rounded-[var(--radius)] bg-muted px-4 py-2 no-underline select-none",
          { "pointer-events-none opacity-50 shadow-none": !page.url.next },
        ]}
        ariaLabel="Next"
      >
        Next
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
