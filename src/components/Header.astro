---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import PixelBottle from "./PixelBottle.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navLinkClass =
  "rounded-full border-2 border-transparent px-3.5 py-2 font-sans text-[15px] font-bold transition-all duration-150 hover:border-border hover:bg-muted";
---

<header class="sticky top-0 z-40 border-b-2 border-border bg-background">
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
  >
    Skip to content
  </a>
  <div
    id="nav-container"
    class="mx-auto flex max-w-app items-center justify-between px-6 py-4"
  >
    <a
      href="/"
      class="flex items-center gap-2.5 font-sans text-[26px] font-black tracking-tight whitespace-nowrap"
    >
      <span
        class="grid size-[34px] place-items-center rounded-lg border-2 border-border bg-[image:var(--gradient)] shadow-[var(--shadow-hard-sm)]"
        style="--byte: #f4f1ea"
      >
        <PixelBottle class="size-6 text-[#1a1a1a]" />
      </span>
      <span>
        lost<em
          class="bg-[image:var(--gradient)] bg-clip-text font-black text-transparent not-italic"
          >bytes</em
        >
      </span>
    </a>
    <nav id="nav-menu" class="relative flex items-center font-sans font-bold">
      <button
        id="menu-btn"
        class="focus-outline border-2 border-border p-2 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "absolute end-6 top-full z-50 mt-2 grid w-48 grid-cols-1 gap-1 rounded-[var(--radius)] border-2 border-border bg-background p-2 shadow-[var(--shadow-hard-sm)]",
          "hidden",
          "sm:static sm:mt-0 sm:flex sm:w-auto sm:flex-row sm:items-center sm:gap-1 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none",
        ]}
      >
        <li>
          <a
            href="/posts"
            class:list={[navLinkClass, { "active-nav": isActive("/posts") }]}
          >
            Notes
          </a>
        </li>
        <li>
          <a
            href="/tags"
            class:list={[navLinkClass, { "active-nav": isActive("/tags") }]}
          >
            Tags
          </a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[navLinkClass, { "active-nav": isActive("/about") }]}
          >
            About
          </a>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="flex items-center justify-center sm:ms-2">
              <button
                id="theme-btn"
                class="focus-outline relative size-[38px] rounded-full border-2 border-border bg-muted shadow-[var(--shadow-hard-sm)] transition-all duration-150 hover:translate-[2px,2px] hover:shadow-[1px_1px_0_var(--shadow-color)]"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] size-4 -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] size-4 -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
        <li class="sm:ms-2">
          <a
            href="/rss.xml"
            class="inline-block rounded-full border-2 border-border bg-yellow px-3.5 py-2 font-sans text-[15px] font-bold text-[#1a1a1a] shadow-[var(--shadow-hard-sm)] transition-all duration-150 hover:translate-[2px,2px] hover:bg-yellow hover:shadow-[1px_1px_0_var(--shadow-color)]"
          >
            RSS ↗
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  document.addEventListener("astro:after-swap", toggleNav);
</script>
