---
export interface Props {
  tag: string;
  tagName: string;
  variant?: "default" | "yellow" | "green";
}

const { tag, tagName, variant = "default" } = Astro.props;

const variantClass = {
  default: "bg-muted text-foreground",
  yellow: "bg-yellow text-[#1a1a1a]",
  green: "bg-green text-[#f4f1ea]",
}[variant];
---

<a
  href={`/tags/${tag}/`}
  transition:name={tag}
  class:list={[
    "inline-block rounded-full border-2 border-border px-3 py-1 font-sans text-xs font-extrabold tracking-wide lowercase transition-colors",
    variantClass,
  ]}
>
  {tagName}
</a>
