---
interface Props {
  title: string;
  href?: string;
  linkLabel?: string;
}

const { title, href, linkLabel } = Astro.props;
---

<div class="mb-6 mt-14 flex items-baseline justify-between gap-4">
  <h2
    class="flex items-center gap-3 font-sans text-[15px] font-black tracking-[0.16em] uppercase before:h-3.5 before:w-[26px] before:shrink-0 before:rounded before:border-2 before:border-border before:bg-[image:var(--gradient)] before:content-['']"
  >
    {title}
  </h2>
  {
    href && linkLabel && (
      <a
        href={href}
        class="border-b-2 border-border font-sans text-[13px] font-extrabold hover:border-accent hover:text-accent"
      >
        {linkLabel}
      </a>
    )
  }
</div>
