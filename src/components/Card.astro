---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import Tag from "./Tag.astro";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

export interface Props extends CollectionEntry<"blog"> {
  variant?: "default" | "big";
}

const { variant = "default", data, id, filePath, body } = Astro.props;

const { title, description, pubDatetime, tags, timezone: postTimezone } = data;

const postUrl = getPath(id, filePath);

const datetime = dayjs(pubDatetime).tz(postTimezone || SITE.timezone);
const dateLabel = datetime.format("D MMM, YYYY");

const wordCount = (body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readingMins = Math.max(1, Math.round(wordCount / 200));

const tagVariants = ["default", "yellow", "green"] as const;
---

<article
  class:list={[
    "lift-card flex flex-col gap-3 bg-muted p-5",
    { "md:col-span-2 bg-card-hover": variant === "big" },
  ]}
>
  <div class="flex flex-wrap gap-1.5">
    {
      tags.slice(0, 3).map((tag, i) => (
        <Tag
          tag={slugifyStr(tag)}
          tagName={tag}
          variant={tagVariants[i % 3]}
        />
      ))
    }
  </div>
  <h3
    class:list={[
      "font-serif font-semibold leading-tight tracking-tight",
      variant === "big" ? "text-[28px]" : "text-[21px]",
    ]}
  >
    <a
      href={postUrl}
      class="card-title-link text-foreground no-underline hover:bg-yellow hover:bg-size-[100%_40%] hover:bg-position-[0_85%] hover:bg-no-repeat dark:hover:rounded dark:hover:bg-size-[100%_100%] dark:hover:text-[#1a1a1a]"
      style={{ viewTransitionName: slugifyStr(title) }}
    >
      {title}
    </a>
  </h3>
  <p class="flex-1 text-[14.5px] text-fg-muted">{description}</p>
  <div
    class="flex items-center justify-between border-t border-dashed border-[var(--line-soft)] pt-3 font-sans text-xs font-bold opacity-60"
  >
    <span>{dateLabel} · {readingMins} min</span>
    <span class="text-base font-black text-green opacity-100">→</span>
  </div>
</article>
