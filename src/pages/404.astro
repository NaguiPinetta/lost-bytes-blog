---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PixelBottle from "@/components/PixelBottle.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="relative mx-auto flex max-w-app flex-1 flex-col items-center justify-center overflow-hidden px-6 py-20"
  >
    <PixelBottle
      class="pointer-events-none absolute opacity-[0.06] text-foreground size-[min(420px,80vw)]"
      style="--byte: currentColor"
    />
    <div class="relative flex flex-col items-center justify-center text-center">
      <h1 class="font-sans text-8xl font-black text-foreground md:text-9xl">
        404
      </h1>
      <p class="mt-4 font-serif text-2xl font-semibold sm:text-3xl">
        Page not found
      </p>
      <p class="mt-3 max-w-md font-serif text-fg-muted italic">
        This byte got lost somewhere between the notebook and the server.
      </p>
      <a
        href="/"
        class="press-btn mt-8 inline-block rounded-[var(--radius)] bg-yellow px-6 py-3 font-sans text-base font-black text-[#1a1a1a] no-underline"
      >
        Go back home →
      </a>
    </div>
  </main>

  <Footer />
</Layout>
