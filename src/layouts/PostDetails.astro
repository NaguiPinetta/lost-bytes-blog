---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import PixelBottle from "@/components/PixelBottle.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone: postTimezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

const allPosts = posts.map(({ data: { title: postTitle }, id, filePath }) => ({
  id,
  title: postTitle,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;

const datetime = dayjs(pubDatetime).tz(postTimezone || SITE.timezone);
const dateLabel = datetime.format("MMMM D, YYYY");
const wordCount = (post.body ?? "")
  .trim()
  .split(/\s+/)
  .filter(Boolean).length;
const readingMins = Math.max(1, Math.round(wordCount / 200));

const tagVariants = ["default", "yellow", "green"] as const;
const primaryTag = tags[0] ? slugifyStr(tags[0]) : "";
---

<Layout {...layoutProps}>
  <Header />

  <section class="relative overflow-hidden border-b-2 border-border px-6 py-12 md:py-14">
    <PixelBottle
      class="pointer-events-none absolute -right-8 -bottom-10 size-[280px] opacity-[0.06] text-foreground"
      style="--byte: currentColor"
    />
    <div class="relative mx-auto max-w-app">
      <nav
        class="mb-4 font-sans text-xs font-extrabold tracking-widest uppercase opacity-60"
        aria-label="breadcrumb"
      >
        <a href="/posts" class="hover:text-accent">Notes</a>
        {
          primaryTag && (
            <>
              {" "}/{" "}
              <a href={`/tags/${primaryTag}/`} class="hover:text-accent">
                {tags[0]}
              </a>
            </>
          )
        }
        {" "}/ {title}
      </nav>
      <h1
        transition:name={slugifyStr(title)}
        class="mb-4 max-w-[24ch] font-serif text-[clamp(30px,4.6vw,50px)] leading-[1.12] font-semibold tracking-tight"
      >
        {title}
      </h1>
      <p class="mb-5 max-w-[60ch] text-lg text-fg-muted italic">{description}</p>
      <div class="mb-4 flex flex-wrap items-center gap-2.5">
        {
          tags.map((tag, i) => (
            <Tag
              tag={slugifyStr(tag)}
              tagName={tag}
              variant={tagVariants[i % 3]}
            />
          ))
        }
        <time
          class="ms-1.5 font-sans text-[13px] font-bold opacity-65"
          datetime={datetime.toISOString()}
        >
          {dateLabel} · {readingMins} min read
        </time>
      </div>
      <div
        class="inline-flex items-center gap-3 rounded-full border-2 border-border bg-muted py-2 pe-4 ps-2"
      >
        <span
          class="grid size-9 place-items-center rounded-full border-2 border-border bg-[image:var(--gradient)] text-[#1a1a1a]"
          style="--byte: #f4f1ea"
        >
          <PixelBottle class="size-[22px]" />
        </span>
        <span class="font-sans text-[12.5px] leading-tight font-bold">
          <b class="block text-[13.5px] font-black">{author}</b>
          {SITE.title} · measured, not marketed
        </span>
      </div>
      {
        SITE.editPost.enabled && !hideEditPost && (
          <div class="mt-4">
            <EditPost {hideEditPost} {post} />
          </div>
        )
      }
    </div>
  </section>

  <main id="main-content" class="mx-auto w-full max-w-app px-6 pb-16">
    <article
      id="article"
      class="app-prose mx-auto mt-12 max-w-[760px]"
    >
      <Content />
    </article>

    <div
      class="mx-auto mt-10 flex max-w-[760px] flex-wrap gap-2 border-t-2 border-border pt-6"
    >
      {tags.map((tag, i) => (
        <Tag
          tag={slugifyStr(tag)}
          tagName={tag}
          variant={tagVariants[i % 3]}
        />
      ))}
    </div>

    <div class="mx-auto mt-8 max-w-[760px]">
      <ShareLinks />
      <BackToTopButton />
    </div>

    <div class="mx-auto mt-10 grid max-w-[760px] gap-4 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="lift-card flex flex-col gap-1.5 bg-muted p-5 no-underline"
          >
            <span class="font-sans text-[11px] font-black tracking-widest uppercase opacity-60">
              Previous
            </span>
            <span class="font-serif text-[17px] leading-snug font-semibold text-foreground">
              {prevPost.title}
            </span>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="lift-card flex flex-col items-end gap-1.5 bg-muted p-5 text-right no-underline sm:col-start-2"
          >
            <span class="font-sans text-[11px] font-black tracking-widest uppercase opacity-60">
              Next
            </span>
            <span class="font-serif text-[17px] leading-snug font-semibold text-foreground">
              {nextPost.title}
            </span>
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");
      if (myBar) {
        myBar.style.width = scrolled + "%";
      }
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded-md border-2 border-border bg-muted px-2 py-1 text-xs leading-4 text-foreground font-sans font-bold`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
