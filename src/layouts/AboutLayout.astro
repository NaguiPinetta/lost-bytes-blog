---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SectionHead from "@/components/SectionHead.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-app px-6 pb-16">
    {
      frontmatter.description && (
        <p class="mt-8 mb-2 max-w-2xl font-serif text-lg text-fg-muted italic">
          {frontmatter.description}
        </p>
      )
    }
    <SectionHead title={frontmatter.title} />
    <section
      id="about"
      class="app-prose mx-auto max-w-[760px] prose-img:border-0"
    >
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
