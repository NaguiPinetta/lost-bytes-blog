---
import SectionHead from "@/components/SectionHead.astro";
import { SITE } from "@/config";

export interface Props {
  pageTitle: string;
  pageDesc?: string;
  linkHref?: string;
  linkLabel?: string;
}

const { pageTitle, pageDesc, linkHref, linkLabel } = Astro.props;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<main
  data-backUrl={backUrl}
  id="main-content"
  class="mx-auto w-full max-w-app px-6 pt-8 pb-12"
>
  <SectionHead title={pageTitle} href={linkHref} linkLabel={linkLabel} />
  {
    pageDesc ? (
      <p class="mb-8 max-w-2xl font-serif text-lg text-fg-muted italic">
        {pageDesc}
      </p>
    ) : null
  }
  <slot />
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const mainContent: HTMLElement | null =
      document.querySelector("#main-content");
    const backUrl = mainContent?.dataset?.backurl;
    if (backUrl) {
      sessionStorage.setItem("backUrl", backUrl);
    }
  });
</script>
